/navigation.min.js
  Cache-Control: public, max-age=2592000, immutable

/app.min.js
  Cache-Control: public, max-age=2592000, immutable

/navigation.js
  Cache-Control: public, max-age=2592000, immutable

/app.js
  Cache-Control: public, max-age=2592000, immutable

/MaaAdyaKali_5.png
  Cache-Control: public, max-age=31536000, immutable

/MaaAdyaKali_5.webp
  Cache-Control: public, max-age=31536000, immutable

/mahakali_sahasranama_meanings.json
  Cache-Control: public, max-age=2592000, immutable

/data_manifest.json
  Cache-Control: public, max-age=2592000, immutable

/data_chunk_*.json
