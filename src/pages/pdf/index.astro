---
const canonical = 'https://1000namesofmakali.com/pdf/';
const title = 'Free PDF Editions | Adya Mahakali 1000 Names';
const description = 'Download the free English and Hindi PDF editions of Adya Mahakali 1000 Names for offline reading and devotional study.';
const englishPdf = 'https://files.jaikhyapaparampara.com/AdyaMahakali_1000names_ebook_Final_V4.pdf';
const hindiPdf = 'https://files.jaikhyapaparampara.com/AdyaMahakali_1000names_ebook_Final_Hindi.pdf';
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': `${canonical}#webpage`,
      name: 'Free PDF Editions of Adya Mahakali 1000 Names',
      description,
      url: canonical,
      inLanguage: 'en',
      isPartOf: {
        '@id': 'https://1000namesofmakali.com/#website'
      },
      about: {
        '@type': 'Thing',
        name: 'Adya Mahakali Sahasranama'
      }
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${canonical}#breadcrumb`,
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: 'https://1000namesofmakali.com/'
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Free PDF Editions',
          item: canonical
        }
      ]
    }
  ]
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://1000namesofmakali.com/MaaAdyaKali_5.webp" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://1000namesofmakali.com/MaaAdyaKali_5.webp" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLMs text summary" />
    <link rel="stylesheet" href="/static-pages.css" />
    <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
  </head>
  <body class="names-static names-static--pdf">
    <main>
      <p class="page-kicker">Free ebook downloads</p>
      <h1>Adya Mahakali 1000 Names PDF Editions</h1>

      <section class="hero-panel">
        <p class="intro">Download free PDF editions of the Adya Mahakali 1000 Names for offline reading, printing, chanting, and devotional study. The English edition is 871 pages, and the Hindi edition is 1,376 pages.</p>
        <nav class="page-nav" aria-label="PDF page navigation">
          <ul>
            <li><a href={englishPdf}>Download English PDF</a></li>
            <li><a href={hindiPdf}>Download Hindi PDF</a></li>
            <li><a href="/names/">Browse the online names hub</a></li>
          </ul>
        </nav>
      </section>

      <section class="ranges-panel" aria-labelledby="download-options-heading">
        <div class="section-heading">
          <p class="section-kicker">Downloads</p>
          <h2 id="download-options-heading">Choose a PDF edition</h2>
        </div>
        <ol class="range-list resource-list">
          <li>
            <a href={englishPdf}>English ebook PDF</a>
            <div>Free 871-page English edition of Adya Mahakali 1000 Names for offline reading and study.</div>
          </li>
          <li>
            <a href={hindiPdf}>Hindi ebook PDF</a>
            <div>Free 1,376-page Hindi edition for readers who prefer the Hindi PDF version.</div>
          </li>
        </ol>
      </section>

      <section class="source-notes" aria-labelledby="pdf-notes-heading">
        <h2 id="pdf-notes-heading">Notes for readers</h2>
        <ul>
          <li>The PDF files are hosted by Khyapa Parampara and are offered as free devotional ebooks.</li>
          <li>The online reader remains useful for search, quick lookup, and direct links to static name ranges.</li>
          <li>For citation of individual names on the web, prefer the <a href="/names/">static names hub</a> and range pages because they are crawlable HTML.</li>
        </ul>
      </section>

      <section class="source-notes" aria-labelledby="related-pages-heading">
        <h2 id="related-pages-heading">Related reference pages</h2>
        <ul>
          <li><a href="/">Interactive Adya Mahakali 1000 Names reader</a></li>
          <li><a href="/names/">Static names hub</a></li>
          <li><a href="/sources/">Sources and editorial notes</a></li>
        </ul>
      </section>
    </main>
  </body>
</html>
