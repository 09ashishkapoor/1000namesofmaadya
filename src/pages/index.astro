    <!-- Version Number and Last Updated Loader -->
    <script is:inline>
    (function() {
        const versionElement = document.getElementById('version-number');
        const lastUpdatedElement = document.getElementById('last-updated');

        if (versionElement || lastUpdatedElement) {
            const versionAssetUrl = window.__ASSET_VERSION__
                ? `/version.json?v=${encodeURIComponent(window.__ASSET_VERSION__)}`
                : '/version.json';

            fetch(versionAssetUrl)
                .then(response => response.json())
                .then(data => {
                    const vEl = document.getElementById('version-number');
                    const luEl = document.getElementById('last-updated');
                    if (vEl) {
                        vEl.textContent = 'V' + data.version;
                    }
                    if (luEl && data.buildDate) {
                        const date = new Date(data.buildDate + 'T00:00:00');
                        const formattedDate = date.toLocaleDateString('en-US', {
                            year: 'numeric',
                            month: 'long',
                            day: 'numeric'
                        });
                        luEl.textContent = formattedDate;
                    }
                })
                .catch(error => {
                    console.warn('Could not load version info:', error);
                    const luEl = document.getElementById('last-updated');
                    if (luEl) {
                        luEl.textContent = new Date().toLocaleDateString('en-US', {
                            year: 'numeric',
                            month: 'long',
                            day: 'numeric'
                        });
                    }
                });
