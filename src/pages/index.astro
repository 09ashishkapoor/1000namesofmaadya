---
// Adya Mahakali Sahasranama - Astro page
import { readFileSync } from 'node:fs';
import { join } from 'node:path';

const assetVersion = Date.now().toString(36);
function versionedAsset(path) {
    return `${path}?v=${assetVersion}`;
}

const firstChunkEntries = JSON.parse(
    readFileSync(join(process.cwd(), 'public', 'data_chunk_1.json'), 'utf8')
);
const dataManifest = JSON.parse(
    readFileSync(join(process.cwd(), 'public', 'data_manifest.json'), 'utf8')
);
const firstPageEntries = firstChunkEntries.slice(0, 11);
const initialNamesPayload = {
    entries: firstPageEntries,
    totalEntries: dataManifest.total,
    totalChunks: dataManifest.chunks,
    chunkSize: dataManifest.chunk_size
};
