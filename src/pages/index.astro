</head>
<body>

    <!-- Landing Page Section -->
    <main>
    <section id="landing-page" class="landing-section" itemscope itemtype="https://schema.org/WebPage">
        <div class="landing-overlay"></div>

        <!-- Landing Content -->
        <div class="landing-content">
            <h1 class="main-title">
                <span class="title-line-main">Adya Mahakali 1000 Names</span>
                <span class="title-line-sub">Sahasranāma</span>
            </h1>

            <p class="title-description">
                A searchable reading of 1,072 names with English meanings
            </p>

            <div class="landing-hero-actions">
                <button id="explore-btn" class="explore-button">
                    <span>Start Reading</span>
                    <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <polyline points="19 12 12 19 5 12"></polyline>
                    </svg>
                </button>
                <button id="learn-btn" class="learn-button">
                    <span>About the Sahasranama</span>
                </button>
            </div>
            <p class="hero-reference-note">
                <a href="/names/" class="hero-reference-link">Browse static names reference pages</a>
            </p>
        </div>
    </section>

    <!-- Names Explorer Section -->
    <section id="names-section" class="names-section">
        <div class="names-overlay"></div>

        <div class="container">
            <header class="names-header">
                <h2 class="section-title">Read, Search, and Sit with Each Name</h2>
                <p class="section-subtitle">
                    Move through the names at your own pace, search by word or meaning, and open any entry for a fuller explanation.
                </p>
            </header>

            <div class="reading-mode-intro">
                <h3 class="reading-mode-title">Begin the Sahasranama</h3>
                <p class="reading-mode-text">The text is arranged in sets of 11 so it is easier to read slowly. Open any card when you want the short meaning and the longer note.</p>
            </div>

            <!-- Controls -->
            <div class="controls-panel">
                <div class="controls-top-row">
                    <button id="search-toggle-btn" class="btn-secondary search-toggle-btn" type="button" aria-expanded="false" aria-controls="search-panel">Open Search</button>

                </div>

                <div id="search-panel" class="search-panel mobile-collapsed">
                    <div class="search-box">
                        <svg class="search-icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8"></circle>
                            <path d="m21 21-4.35-4.35"></path>
                        </svg>
                        <input type="text" id="search-input" placeholder="Search by name or meaning..." autocomplete="off" aria-label="Search sacred names">
                    </div>

                    <div class="filters-row">
                        <button id="clear-btn" class="btn-secondary" disabled>Clear</button>
                    </div>

                    <div class="stats-display" id="stats-display" role="status">
                        📿 Showing all <strong>1072</strong> names of <strong>Maa Adya Mahakali</strong>
                    </div>
                </div>
            </div>

            <!-- Loading State -->
            <div id="loading-state" class="loading-state hidden">
                <div class="loader"></div>
                <p id="loading-message">Loading names...</p>
            </div>

            <!-- Error State -->
            <div id="error-state" class="error-state hidden" role="alert">
                <div class="error-icon">⚠️</div>
                <h3>Could not load the names</h3>
                <p id="error-message"></p>
                <button id="retry-btn" class="btn-secondary" type="button">Try loading again</button>
            </div>

            <!-- Names Grid -->
            <div id="names-grid" class="names-grid" data-prerendered="true">
                {firstPageEntries.map((entry, index) => (
                    <div
                        class="name-card visible"
                        data-prerendered="true"
                        style={`animation-delay: ${(index % 11) * 0.05}s`}
                    >
                        <div class="card-header">
                            <span class="card-index">#{entry.index}</span>
                        </div>

                        <h3 class="card-name">{entry.english_name}</h3>

                        <button
                            class="toggle-btn"
                            data-index={entry.index}
                            data-prerendered="true"
                            type="button"
                            aria-expanded="false"
                            aria-controls={`elaboration-${entry.index}`}
                        >
                            <span class="toggle-btn-label">Read More</span>
                            <svg class="chevron" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="6 9 12 15 18 9"></polyline>
                            </svg>
                        </button>

                        <div class="elaboration" data-index={entry.index} id={`elaboration-${entry.index}`} aria-hidden="true">
                            <div class="elaboration-content" tabindex="-1">
                                <p class="card-meaning">{entry.english_one_line}</p>
                                <div class="elaboration-copy">{entry.english_elaboration}</div>
                            </div>
                        </div>
                    </div>
                ))}
            </div>

            <div class="load-more-container reading-pagination">
                <button id="prev-page-btn" class="btn-secondary hidden" type="button">Previous 11</button>
                <div id="reading-progress" class="reading-progress" aria-live="polite">Showing <strong>1</strong>-<strong>11</strong> of <strong>{dataManifest.total}</strong></div>
                <button id="next-page-btn" class="btn-primary" type="button">Next 11</button>
            </div>

            <!-- eBook Download Promo Section -->
            <section class="ebook-promo-section">
                <div class="ebook-promo-container">
                    <div class="ebook-promo-card">
                        <div class="ebook-promo-header">
                            <span class="ebook-promo-badge">📖 Digital Library</span>
                            <h3 class="ebook-promo-title">Download the PDF Editions</h3>
                        </div>
                        <p class="ebook-promo-text">
                            If you want an offline copy, the same text on this site is also available as free PDF editions.
                            They include the full set of names with English meanings and elaborations in a format that is easier to save, share, or print.
                        </p>
                        <ul class="ebook-features">
                            <li>📥 <strong>Free to download</strong>: No registration required</li>
                            <li>📄 <strong>Several PDF versions</strong>: Choose the format you want</li>
                            <li>🌐 <strong>Full set included</strong>: All 1000+ names with meanings</li>
                            <li>🔖 <strong>Easy to keep offline</strong>: Read without a connection</li>
                            <li>🖨️ <strong>Formatted for printing</strong>: Ready for home or temple use</li>
                        </ul>
                        <a href="https://www.jaikhyapaparampara.com" target="_blank" rel="noopener noreferrer" class="ebook-cta-btn">
                            Open the Khyapa Parampara Library
                            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                                <polyline points="15 3 21 3 21 9"></polyline>
                                <line x1="10" y1="14" x2="21" y2="3"></line>
                            </svg>
                        </a>
