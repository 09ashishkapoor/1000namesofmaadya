# Global headers for all files
/*
  # Enable Brotli and Gzip compression for text files (Cloudflare handles this automatically)
  # This header tells Cloudflare to compress responses

/mahakali_sahasranama_meanings.json
  X-Robots-Tag: noindex, nofollow
  Cache-Control: public, max-age=2592000, immutable

# Cache rules for static assets to improve CDN performance
/site.min.css
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/styles.min.css
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/navigation.min.js
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/app.min.js
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/translations.js
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/version.json
  Cache-Control: public, max-age=300, stale-while-revalidate=86400

/MaaAdyaKali_5.png
  Cache-Control: public, max-age=31536000, immutable

/MaaAdyaKali_5.webp
  Cache-Control: public, max-age=31536000, immutable

/data_manifest.json
  Cache-Control: public, max-age=300, stale-while-revalidate=86400

/data_chunk_*.json
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# Ensure robots.txt served as plain text with a healthy edge cache
/robots.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
